# ============================================
# EJEMPLO DE VARIABLES DE ENTORNO
# ============================================
# Copia este archivo a .env en la raíz del proyecto
# NO commits .env a git (agrega a .gitignore)

# ============================================
# SPRING BOOT - BACKEND VENTAS
# ============================================
SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:mysql://mysql-ventas:3306/tienda_ventas
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=admin123
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# JVM Options - Backend Ventas
JAVA_OPTS_VENTAS=-Xmx512m -Xms256m

# ============================================
# SPRING BOOT - BACKEND DESPACHOS
# ============================================
SPRING_DATASOURCE_URL_DESPACHOS=jdbc:mysql://mysql-despachos:3306/tienda_despachos
SPRING_DATASOURCE_USERNAME_DESPACHOS=root
SPRING_DATASOURCE_PASSWORD_DESPACHOS=admin123

# JVM Options - Backend Despachos
JAVA_OPTS_DESPACHOS=-Xmx512m -Xms256m

# ============================================
# FRONTEND
# ============================================
NODE_ENV=production
VITE_API_VENTAS_URL=http://localhost:8080
VITE_API_DESPACHOS_URL=http://localhost:8081

# ============================================
# DOCKER COMPOSE
# ============================================
COMPOSE_PROJECT_NAME=tienda-shop
